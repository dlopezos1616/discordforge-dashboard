# ============================================
# DiscordForge - Variables de Entorno
# ============================================
# Copia este archivo como .env y rellena los valores
# cp .env.example .env

# ============================================
# BASE DE DATOS (PostgreSQL)
# ============================================
# Opción 1: Vercel Postgres (recomendado para Vercel)
# DATABASE_URL="postgres://default:xxxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"

# Opción 2: Neon Database
# DATABASE_URL="postgresql://neondb_owner:xxxxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Opción 3: Supabase
# DATABASE_URL="postgresql://postgres:xxxxx@db.xxx.supabase.co:5432/postgres"

# Opción 4: Railway
# DATABASE_URL="postgresql://postgres:xxxxx@containers-us-west-xxx.railway.app:6543/railway"

DATABASE_URL=""

# ============================================
# WEBSOCKET BRIDGE (solo para Vercel)
# ============================================
# URL del servidor WS Bridge donde se conecta el dashboard
# En desarrollo local no hace falta (usa el mismo origin)
# En Vercel, debe apuntar al servidor donde corre el WS Bridge
# NEXT_PUBLIC_WS_URL="https://ws.tudominio.com"

# ============================================
# DISCORD BOT (para el mini-servicio discord-bot)
# ============================================
DISCORD_BOT_TOKEN=""
DISCORD_CLIENT_ID=""

# ============================================
# ADMIN PASSWORD (para login del dashboard)
# ============================================
ADMIN_PASSWORD="admin123"
